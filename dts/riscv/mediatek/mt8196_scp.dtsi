/dts-v1/;

#include <freq.h>

/ {
	#address-cells = < 0x01 >;
	#size-cells = < 0x01 >;

	uart0: uart@70026000 {
		compatible = "mediatek,mrv55-uart";
		reg = <0x70026000 0x1000>;
		current-speed = <115200>;
		clock-frequency = <DT_FREQ_M(26)>;
	};
	cpus {
		#address-cells = < 0x01 >;
		#size-cells = < 0x00 >;

		cpu@0 {
			device_type = "cpu";
			reg = < 0x00 >;
			status = "okay";
			compatible = "riscv";
			riscv,isa-base = "rv32i";
			riscv,isa-extensions = "i", "m", "a", "f", "d", "c", "zicsr", "zifencei";
			clock-frequency = <DT_FREQ_M(13)>;
		};

	};
	ram0: memory@0 {
		device_type = "memory";
		reg = <0x0 0x360000>;
	};

};
